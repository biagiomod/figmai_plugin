# ACE static deployment -- Apache / cPanel
#
# Copy this file into the same directory as index.html on your web host.

# ─── Cache control ───────────────────────────────────────────────────
# config.js and app.js: never cache (so config changes + code updates apply immediately)
<FilesMatch "(config\.js|app\.js)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
  </IfModule>
</FilesMatch>

# CSS: short cache (1 day)
<FilesMatch "\.css$">
  <IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 day"
  </IfModule>
</FilesMatch>

# Fonts: long cache (30 days)
<FilesMatch "\.(otf|woff|woff2|ttf|eot)$">
  <IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 30 days"
  </IfModule>
</FilesMatch>

# SVG icons: moderate cache (7 days)
<FilesMatch "\.svg$">
  <IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 7 days"
  </IfModule>
</FilesMatch>

# ─── Security headers ────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ─── MIME types ──────────────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType font/opentype .otf
  AddType image/svg+xml .svg
</IfModule>
