# Shared wrapper token for BOTH services (ace-wrapper and ace-node).
# Copy this file to .env for local use:
#   cp .env.example .env
# If you rotate WRAPPER_TOKEN, recreate both containers so they stay in sync:
#   docker compose -f docker-compose.example.yml up --build --force-recreate
# For internal/prod deployments, replace with a strong random value:
#   openssl rand -hex 32
WRAPPER_TOKEN=dev-wrapper-token-local-only
