.DS_Store
*.log
*.css.d.ts



node_modules/
**/node_modules/

# Backup files
*.bak
*.bak2
*.bak3
*.clean
*.final
*.fix

# Admin Config Editor backups (local only)
admin-editor/.backups/
admin-editor/.env.deploy
admin-editor/dist/

# ACE frontend runtime config — environment-specific, never committed.
# Copy admin-editor/public/config.local.example.js  → config.js  for local dev (npm run admin)
# Copy admin-editor/public/config.aws.example.js    → config.js  for AWS/hosted ACE
admin-editor/public/config.js

# Generated build info (created at build time). build/build-info.json is committed so ACE has a value in dev.
src/generated/buildInfo.ts

# ACE Spring Wrapper — custom deployment config (never committed; contains secrets)
**/custom-ace.yml

# Spring wrapper build artifacts
enterprise/ace-spring-wrapper/target/
enterprise/ace-spring-wrapper/logs/
enterprise/ace-spring-wrapper/.env
infra/config-api/.aws-sam/
infra/config-api/samconfig.toml
infra/config-api/dist/

# Work-only override files (not committed to Public repo)
# Exception: workAdapter.override.ts has a committed no-op stub for build stability
src/work/credentials.override.ts
src/work/*.override.ts
!src/work/workAdapter.override.ts

# Local branding override (never committed)
custom/branding.local.json
custom/.config-snapshot-id

# Local personal/dev config override — carries dev domains, never committed.
# Copy custom/config.local.example.json → custom/config.local.json and fill in your values.
custom/config.local.json

# Local font files — binary assets, placed manually, never committed.
# See src/assets/fonts/README.md for accepted filenames and formats.
src/assets/fonts/*.woff2
src/assets/fonts/*.woff
src/assets/fonts/*.ttf

# Plugin manifest — generated at build time from package.json + config.
# Never commit: it changes with every build and would pin local dev domains into the repo.
# Regenerated by: npm run build  (or npm run watch for the first run)
manifest.json

.worktrees/
.superpowers/
