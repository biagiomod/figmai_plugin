// Tags for Assistants buttons in the Select Assistant modal

// ### Soft Warning Tag - Beta as default but label can be changed as needed ###


{
    "type": "FRAME",
    "name": "Tag - Soft Warning",
    "layout": {
      "mode": "HORIZONTAL",
      "padding": {
        "top": 4,
        "right": 8,
        "bottom": 4,
        "left": 8
      },
      "itemSpacing": 0,
      "sizing": {
        "primary": "AUTO",
        "counter": "AUTO"
      }
    },
    "width": 41,
    "height": 21,
    "visual": {
      "fills": [
        {
          "type": "SOLID",
          "color": {
            "r": 1,
            "g": 0.7038756012916565,
            "b": 0.2275014966726303
          }
        }
      ],
      "strokeWeight": 1,
      "strokeAlign": "INSIDE",
      "cornerRadius": 8
    },
    "children": [
      {
        "type": "TEXT",
        "name": "Text",
        "width": 25,
        "height": 13,
        "visual": {
          "fills": [
            {
              "type": "SOLID",
              "color": {
                "r": 0.36012619733810425,
                "g": 0.22207783162593842,
                "b": 0
              }
            }
          ],
          "strokeWeight": 1,
          "strokeAlign": "OUTSIDE"
        },
        "text": {
          "characters": "Beta",
          "fontFamily": "Inter",
          "fontStyle": "Bold",
          "fontSize": 11,
          "lineHeight": {
            "unit": "AUTO"
          },
          "letterSpacing": {
            "unit": "PERCENT",
            "value": 0
          },
          "textAlignHorizontal": "CENTER",
          "textAlignVertical": "TOP",
          "textCase": "ORIGINAL"
        }
      }
    ]
  }



