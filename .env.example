# S3 config sync (Phase 1 manual workflow)
# Leave S3_BUCKET empty for local-only development.
S3_BUCKET=
S3_REGION=us-east-1
S3_PREFIX=figmai/

# Optional: pin build/sync to a specific snapshot.
CONFIG_SNAPSHOT_ID=

# Optional: author metadata for seed/push manifests.
CONFIG_AUTHOR=dev-user@example.com
