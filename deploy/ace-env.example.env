# deploy/ace-env.example.env
# Copy to deploy/ace-env.env (gitignored). Fill in values for your environment.
# NEVER put secrets in this file.

# ── S3 ─────────────────────────────────────────────────────────────────────
S3_BUCKET=your-bucket-name
S3_PREFIX=figmai/
S3_REGION=us-east-1

# ── Config API ──────────────────────────────────────────────────────────────
# Populate after first sam deploy. No trailing slash.
# Example: https://abc123.execute-api.us-east-1.amazonaws.com
ACE_API_BASE=https://<api-id>.execute-api.<region>.amazonaws.com

# ── SAM deploy ──────────────────────────────────────────────────────────────
SAM_STACK_NAME=ace-config-api
SAM_REGION=us-east-1
SAM_ARTIFACT_BUCKET=your-sam-artifact-bucket

# ── CORS ────────────────────────────────────────────────────────────────────
# Exact origins only — scheme + host + optional port, no path, no trailing slash.
# Must match ACE_PUBLIC_URL exactly.
# Example: https://ace.example.internal
# Example (multiple): https://ace.example.internal,https://ace-staging.example.internal
CORS_ALLOW_ORIGINS=https://ace.example.internal

# ── Static ACE hosting ──────────────────────────────────────────────────────
# ACE_PUBLIC_URL: the URL the static ACE is served from. Must match CORS_ALLOW_ORIGINS.
# No trailing slash.
ACE_PUBLIC_URL=https://ace.example.internal

# STATIC_DEPLOY_PATH: local or remote path where admin-editor/dist/ is uploaded.
# Examples:
#   /var/www/ace              (local web server document root)
#   user@host:/var/www/ace    (rsync target)
#   s3://your-bucket/ace/     (S3 static hosting)
STATIC_DEPLOY_PATH=/var/www/ace

# authMode: always 'bearer' for hosted deployments.
ACE_AUTH_MODE=bearer

# ── Seed author (used by seed-s3.ts) ────────────────────────────────────────
CONFIG_AUTHOR=your-name-or-team

# ── SAM metadata (returned by /api/health) ──────────────────────────────────
SERVICE_NAME=ace-config-api
SERVICE_VERSION=0.1.0

# ── SECRETS — never put these here ──────────────────────────────────────────
# CONFIG_API_TOKEN  → --parameter-overrides at sam deploy, AWS SSM, or CI secret
# AWS credentials   → ~/.aws/credentials or CI environment injection
